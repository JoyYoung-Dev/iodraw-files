{"root":{"data":{"id":"dhssgjevhz40","created":1776160809379,"text":"财务工作台"},"children":[{"data":{"id":"dhssh7axhq00","created":1776160861383,"text":"采购单付款"},"children":[{"data":{"id":"dhssigeqwj40","created":1776160959569,"text":"采购单付款申请"},"children":[{"data":{"id":"dhsskkp7o1c0","created":1776161125638,"text":"采购单列表页面提交付款案件，生成attempt送到采购单付款审核，此时默认不使用供应商欠款"},"children":[]}]},{"data":{"id":"dhssjehvudc0","created":1776161033770,"text":"采购单付款审核"},"children":[{"data":{"id":"dhssli63l9k0","created":1776161198493,"text":"总览所有采购单付款申请，在此处审核"},"children":[{"data":{"id":"dhssor4e5c80","created":1776161453073,"text":"核对发票"},"children":[]},{"data":{"id":"dhssovkwwk00","created":1776161462779,"text":"付款操作"},"children":[]},{"data":{"id":"dhssoxakoqg0","created":1776161466507,"text":"上传付款凭证"},"children":[]},{"data":{"id":"dhssp6v32bs0","created":1776161487339,"text":"拒绝"},"children":[]}]}]}]},{"data":{"id":"dhssh89up6w0","created":1776160863495,"text":"采购单款项追踪"},"children":[{"data":{"id":"dhssp9z4uaw0","created":1776161494114,"text":"全部采购单"},"children":[{"data":{"id":"dhsss4i6j1c0","created":1776161717297,"text":"对账：匹配采购单和Airwallex或其他付款方式，用于同步系统中采购单和真实付款操作的状态"},"children":[]}]},{"data":{"id":"dhssrx19u940","created":1776161701037,"text":"已批准未付款"},"children":[{"data":{"id":"dhsst43iqe80","created":1776161794775,"text":"已批准但未生成采购单的报价"},"children":[{"data":{"id":"dhssv06wv0g0","created":1776161943001,"text":"只是监控和提醒采购，并且会过滤掉已经预申请付款的报价"},"children":[]}]},{"data":{"id":"dhssulgd7680","created":1776161910921,"text":"未申请付款采购单"},"children":[{"data":{"id":"dhssve87z340","created":1776161973555,"text":"完全没有申请记录的采购单"},"children":[]}]}]},{"data":{"id":"dhssrxaizxc0","created":1776161701597,"text":"分支主题"},"children":[]},{"data":{"id":"dhssrxgrl1k0","created":1776161701974,"text":"分支主题"},"children":[]},{"data":{"id":"dhssrxmu6200","created":1776161702341,"text":"分支主题"},"children":[]}]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}